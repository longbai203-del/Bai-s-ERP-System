{
  "include": [
    "assets/js/phoenix*.js"
  ],
  "compilerOptions": {
    "target": "es2016",                       
    "module": "ESNext",                       
    "moduleResolution": "bundler",            
    "rootDir": "./assets/js/phoenix",         
    "allowJs": true,                          
    "declaration": true,                      
    "declarationMap": true,                   
    "emitDeclarationOnly": true,              
    "outDir": "./priv/static/types",          
    "esModuleInterop": true,                  
    "forceConsistentCasingInFileNames": true, 
    "strict": true,                           
    "skipLibCheck": true                      
  }
}

