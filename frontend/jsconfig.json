{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@shared/*": ["./shared/*"],
            "@api/*": ["./api/*"],
            "@core/*": ["./frontend/js/core/*"]
        }
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*",
        "dist",
        "build"
    ]
}