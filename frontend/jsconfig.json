{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@core/*": ["./src/core/*"],
            "@components/*": ["./src/components/*"],
            "@services/*": ["./src/services/*"],
            "@utils/*": ["./src/utils/*"],
            "@modules/*": ["./src/modules/*"],
            "@views/*": ["./src/views/*"],
            "@assets/*": ["./src/assets/*"]
        },
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true
    },
    "include": ["src/**/*.js", "src/**/*.vue"],
    "exclude": ["node_modules", "dist"]
}