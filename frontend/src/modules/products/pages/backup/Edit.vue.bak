<template>
  <div class="products-edit-page">
    <!-- 页面标题 -->
    <div class="page-header">
      <div class="header-left">
        <el-button @click="handleBack">
          <el-icon><ArrowLeft /></el-icon> 返回详情
        </el-button>
        <h1>
          <el-icon :size="28" color="#4F46E5"><Edit /></el-icon>
          编辑产品
        </h1>
        <el-tag :type="formData.status === 'active' ? 'success' : 'danger'" size="large" effect="dark">
          {{ formData.status === 'active' ? '上架' : '下架' }}
        </el-tag>
      </div>
      <div class="header-actions">
        <el-button @click="handleReset">
          <el-icon><Refresh /></el-icon> 重置
        </el-button>
        <el-button type="primary" :loading="submitting" @click="handleSubmit">
          <el-icon><Check /></el-icon> 更新
        </el-button>
      </div>
    </div>

    <!-- 表单 -->
    <el-card class="form-card" shadow="hover" v-loading="loading">
      <el-form
        ref="formRef"
        :model="formData"
        :rules="formRules"
        label-width="130px"
        label-position="right"
      >
        <!-- 基本信息 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            基本信息
          </div>

          <el-row :gutter="24">
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="产品名称" prop="name">
                <el-input v-model="formData.name" placeholder="请输入产品名称" clearable />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="产品编号" prop="code">
                <el-input v-model="formData.code" disabled />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="分类" prop="category">
                <el-select v-model="formData.category" placeholder="请选择分类" style="width: 100%">
                  <el-option label="洗车" value="洗车" />
                  <el-option label="美容" value="美容" />
                  <el-option label="保养" value="保养" />
                  <el-option label="配件" value="配件" />
                  <el-option label="套餐" value="套餐" />
                  <el-option label="会员" value="会员" />
                </el-select>
              </el-form-item>
            </el-col>
          </el-row>
        </div>

        <!-- 价格与库存 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            价格与库存
          </div>

          <el-row :gutter="24">
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="售价" prop="price">
                <el-input-number
                  v-model="formData.price"
                  :min="0"
                  :precision="2"
                  :max="999999.99"
                  controls-position="right"
                  style="width: 100%"
                />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="成本" prop="cost">
                <el-input-number
                  v-model="formData.cost"
                  :min="0"
                  :precision="2"
                  :max="999999.99"
                  controls-position="right"
                  style="width: 100%"
                />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="库存数量" prop="stock">
                <el-input-number
                  v-model="formData.stock"
                  :min="0"
                  :max="999999"
                  controls-position="right"
                  style="width: 100%"
                />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="单位" prop="unit">
                <el-select v-model="formData.unit" placeholder="请选择单位" style="width: 100%">
                  <el-option label="个" value="个" />
                  <el-option label="件" value="件" />
                  <el-option label="瓶" value="瓶" />
                  <el-option label="盒" value="盒" />
                  <el-option label="套" value="套" />
                  <el-option label="张" value="张" />
                  <el-option label="kg" value="kg" />
                  <el-option label="g" value="g" />
                  <el-option label="L" value="L" />
                  <el-option label="ml" value="ml" />
                </el-select>
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="状态" prop="status">
                <el-select v-model="formData.status" placeholder="请选择状态" style="width: 100%">
                  <el-option label="上架" value="active" />
                  <el-option label="下架" value="inactive" />
                </el-select>
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="品牌" prop="brand">
                <el-select v-model="formData.brand" placeholder="请选择品牌" style="width: 100%" filterable>
                  <el-option label="3M" value="3M" />
                  <el-option label="Turtle Wax" value="Turtle Wax" />
                  <el-option label="Meguiars" value="Meguiars" />
                  <el-option label="SONAX" value="SONAX" />
                  <el-option label="CarPro" value="CarPro" />
                  <el-option label="其他" value="其他" />
                </el-select>
              </el-form-item>
            </el-col>
          </el-row>
        </div>

        <!-- 描述 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            产品描述
          </div>

          <el-row :gutter="24">
            <el-col :span="24">
              <el-form-item label="描述" prop="description">
                <el-input
                  v-model="formData.description"
                  type="textarea"
                  :rows="4"
                  placeholder="请输入产品描述信息"
                  maxlength="500"
                  show-word-limit
                />
              </el-form-item>
            </el-col>
          </el-row>
        </div>

        <!-- 产品图片 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            产品图片
            <span class="section-tip">支持上传 JPG、PNG 格式</span>
          </div>

          <el-row :gutter="24">
            <el-col :span="24">
              <el-upload
                ref="uploadRef"
                action="#"
                :auto-upload="false"
                :file-list="fileList"
                :on-change="handleFileChange"
                :on-remove="handleFileRemove"
                :on-preview="handleFilePreview"
                :limit="5"
                :on-exceed="handleExceed"
                list-type="picture-card"
                multiple
              >
                <el-icon><Plus /></el-icon>
              </el-upload>

              <!-- 已上传图片 -->
              <div v-if="existingImages.length > 0" class="existing-images">
                <div class="file-section-title">已上传图片</div>
                <div class="existing-image-list">
                  <div
                    v-for="(img, index) in existingImages"
                    :key="index"
                    class="existing-image-item"
                  >
                    <img :src="img" alt="产品图片" />
                    <div class="image-actions">
                      <el-button type="danger" size="small" circle @click="handleRemoveExisting(index)">
                        <el-icon><Delete /></el-icon>
                      </el-button>
                    </div>
                  </div>
                </div>
              </div>
            </el-col>
          </el-row>
        </div>

        <!-- 表单底部 -->
        <el-divider />
        <div class="form-footer">
          <div class="footer-left">
            <el-button @click="handleBack">
              <el-icon><ArrowLeft /></el-icon> 返回
            </el-button>
          </div>
          <div class="footer-right">
            <el-button @click="handleReset">
              <el-icon><Refresh /></el-icon> 重置
            </el-button>
            <el-button type="primary" :loading="submitting" @click="handleSubmit">
              <el-icon><Check /></el-icon> 更新
            </el-button>
          </div>
        </div>
      </el-form>
    </el-card>

    <!-- 更新确认对话框 -->
    <el-dialog
      v-model="submitDialogVisible"
      title="更新确认"
      width="440px"
      :close-on-click-modal="false"
    >
      <div class="submit-confirm">
        <el-icon color="#e6a23c" size="56"><Warning /></el-icon>
        <p>确定要更新该产品吗？</p>
        <div class="summary">
          <div class="summary-row">
            <span>名称：</span>
            <strong>{{ formData.name || '未填写' }}</strong>
          </div>
          <div class="summary-row">
            <span>分类：</span>
            <strong>{{ formData.category || '未选择' }}</strong>
          </div>
          <div class="summary-row">
            <span>售价：</span>
            <strong style="color: #409eff;">¥{{ formatNumber(formData.price) }}</strong>
          </div>
          <div class="summary-row">
            <span>库存：</span>
            <strong>{{ formData.stock }} {{ formData.unit || '个' }}</strong>
          </div>
          <div class="summary-row">
            <span>状态：</span>
            <strong>{{ formData.status === 'active' ? '上架' : '下架' }}</strong>
          </div>
        </div>
        <p class="hint">更新后产品信息将同步更新</p>
      </div>
      <template #footer>
        <el-button @click="submitDialogVisible = false">取消</el-button>
        <el-button type="primary" :loading="submitting" @click="confirmSubmit">
          确定更新
        </el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup lang="ts">
import { ref, reactive, onMounted } from 'vue'
import { useRouter, useRoute } from 'vue-router'
import { ElMessage, ElMessageBox } from 'element-plus'
import type { FormInstance, FormRules, UploadInstance, UploadFile } from 'element-plus'
import {
  ArrowLeft,
  Edit,
  Refresh,
  Check,
  Plus,
  Delete,
  Warning,
  Picture,
  UploadFilled
} from '@element-plus/icons-vue'

const router = useRouter()
const route = useRoute()

// ========== 响应式数据 ==========
const formRef = ref<FormInstance>()
const uploadRef = ref<UploadInstance>()
const loading = ref(false)
const submitting = ref(false)
const submitDialogVisible = ref(false)

// 表单数据
const formData = reactive({
  id: 0,
  name: '',
  code: '',
  category: '',
  price: 0,
  cost: 0,
  stock: 0,
  unit: '个',
  status: 'active',
  brand: '',
  description: ''
})

// 文件列表
const fileList = ref<UploadFile[]>([])
const existingImages = ref<string[]>([
  'https://via.placeholder.com/100x100/409eff/ffffff?text=Image+1',
  'https://via.placeholder.com/100x100/67c23a/ffffff?text=Image+2'
])

// ========== 表单验证规则 ==========
const formRules: FormRules = {
  name: [
    { required: true, message: '请输入产品名称', trigger: 'blur' },
    { min: 2, max: 100, message: '名称长度在 2 到 100 个字符', trigger: 'blur' }
  ],
  category: [
    { required: true, message: '请选择分类', trigger: 'change' }
  ],
  price: [
    { required: true, message: '请输入售价', trigger: 'blur' },
    { type: 'number', min: 0, message: '售价不能为负数', trigger: 'blur' }
  ],
  stock: [
    { required: true, message: '请输入库存数量', trigger: 'blur' },
    { type: 'number', min: 0, message: '库存不能为负数', trigger: 'blur' }
  ],
  unit: [
    { required: true, message: '请选择单位', trigger: 'change' }
  ],
  status: [
    { required: true, message: '请选择状态', trigger: 'change' }
  ]
}

// ========== 计算属性 ==========
const formatNumber = (num: number) => {
  return num.toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

// ========== 获取详情数据 ==========
const fetchDetail = async () => {
  const id = route.params.id as string
  if (!id) {
    ElMessage.error('无效的产品ID')
    router.push('/products')
    return
  }

  loading.value = true
  try {
    await new Promise(resolve => setTimeout(resolve, 600))

    const mockData = {
      id: parseInt(id),
      name: `产品 ${id}`,
      code: `P-${String(id).padStart(6, '0')}`,
      category: ['洗车', '美容', '保养', '配件', '套餐', '会员'][parseInt(id) % 6],
      price: Math.round((Math.random() * 500 + 20) * 100) / 100,
      cost: Math.round((Math.random() * 300 + 10) * 100) / 100,
      stock: Math.floor(Math.random() * 100),
      unit: ['个', '件', '瓶', '盒', '套', '张'][parseInt(id) % 6],
      status: ['active', 'active', 'inactive', 'active'][parseInt(id) % 4],
      brand: ['3M', 'Turtle Wax', 'Meguiars', 'SONAX', 'CarPro'][parseInt(id) % 5],
      description: '这是一条示例产品描述信息，包含产品的详细说明和特点。'
    }

    Object.assign(formData, mockData)
  } catch (error) {
    ElMessage.error('加载数据失败，请重试')
  } finally {
    loading.value = false
  }
}

// ========== 附件处理 ==========
const handleFileChange = (file: UploadFile, fileList: UploadFile[]) => {
  if (file.size && file.size > 5 * 1024 * 1024) {
    ElMessage.warning('图片大小不能超过5MB')
    const index = fileList.indexOf(file)
    if (index > -1) {
      fileList.splice(index, 1)
    }
    return
  }

  const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp']
  if (file.raw && !allowedTypes.includes(file.raw.type)) {
    ElMessage.warning('只支持 JPG、PNG、GIF、WEBP 格式')
    const index = fileList.indexOf(file)
    if (index > -1) {
      fileList.splice(index, 1)
    }
    return
  }
}

const handleFileRemove = (file: UploadFile, fileList: UploadFile[]) => {}

const handleFilePreview = (file: UploadFile) => {
  if (file.url) {
    window.open(file.url, '_blank')
  }
}

const handleExceed = () => {
  ElMessage.warning('最多只能上传5张图片')
}

const handleRemoveExisting = (index: number) => {
  ElMessageBox.confirm('确定要删除该图片吗？', '提示', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  }).then(() => {
    existingImages.value.splice(index, 1)
    ElMessage.success('图片已删除')
  }).catch(() => {})
}

// ========== 表单操作 ==========
const handleBack = () => {
  router.push(`/products/detail/${formData.id}`)
}

const handleReset = () => {
  ElMessageBox.confirm('确定要重置表单吗？所有未保存的数据将丢失', '确认重置', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  }).then(() => {
    fetchDetail()
    ElMessage.success('已重置')
  }).catch(() => {})
}

const handleSubmit = async () => {
  if (!formRef.value) return
  try {
    await formRef.value.validate()
  } catch {
    return
  }

  submitDialogVisible.value = true
}

const confirmSubmit = async () => {
  submitting.value = true
  try {
    await new Promise(resolve => setTimeout(resolve, 1200))
    ElMessage.success('产品更新成功！')
    submitDialogVisible.value = false
    router.push(`/products/detail/${formData.id}`)
  } catch (error) {
    ElMessage.error('更新失败，请重试')
  } finally {
    submitting.value = false
  }
}

// ========== 生命周期 ==========
onMounted(() => {
  fetchDetail()
})
</script>

<style scoped>
