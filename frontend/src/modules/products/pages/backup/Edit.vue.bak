  margin-bottom: 0;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 15px;
  font-weight: 600;
  color: #303133;
  margin-bottom: 20px;
  flex-wrap: wrap;
  gap: 8px;
}

.section-indicator {
  display: inline-block;
  width: 4px;
  height: 18px;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  border-radius: 2px;
  margin-right: 10px;
}

.section-tip {
  font-size: 12px;
  font-weight: 400;
  color: #909399;
  margin-left: 8px;
}

.existing-images {
  margin-top: 16px;
}

.file-section-title {
  font-size: 13px;
  font-weight: 500;
  color: #606266;
  margin-bottom: 8px;
}

.existing-image-list {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.existing-image-item {
  position: relative;
  width: 100px;
  height: 100px;
  border-radius: 8px;
  border: 1px solid #ebeef5;
  overflow: hidden;
}

.existing-image-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-actions {
  position: absolute;
  top: 4px;
  right: 4px;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.existing-image-item:hover .image-actions {
  opacity: 1;
}

.form-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  padding: 8px 0;
}

.footer-left,
.footer-right {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.submit-confirm {
  text-align: center;
  padding: 16px 0;
}

.submit-confirm p {
  margin: 12px 0 0;
  font-size: 16px;
  color: #606266;
}

.submit-confirm .hint {
  font-size: 13px;
  color: #909399;
  margin-top: 4px;
}

.summary {
  margin: 16px 0;
  padding: 16px;
  background: #f5f7fa;
  border-radius: 8px;
  text-align: left;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 4px 0;
  font-size: 14px;
  color: #606266;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-row strong {
  color: #303133;
}

:deep(.el-upload--picture-card) {
  width: 100px;
  height: 100px;
  line-height: 100px;
}

@media (max-width: 768px) {
  .products-edit-page {
    padding: 12px;
  }

  .page-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .header-actions {
    width: 100%;
  }

  .header-actions .el-button {
    flex: 1;
  }

  .form-section {
    padding: 16px;
  }

  .form-footer {
    flex-direction: column;
    align-items: stretch;
  }

  .footer-left,
  .footer-right {
    justify-content: stretch;
  }

  .footer-left .el-button,
  .footer-right .el-button {
    flex: 1;
  }

  .existing-image-list {
    justify-content: center;
  }
}
</style>