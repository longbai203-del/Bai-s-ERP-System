<script setup lang="ts">
import { ref, reactive, onMounted } from 'vue'
import { useRouter, useRoute } from 'vue-router'
import { ElMessage, ElMessageBox } from 'element-plus'
import type { FormInstance, FormRules, UploadInstance, UploadFile } from 'element-plus'
import {
  ArrowLeft,
  Edit,
  Refresh,
  Check,
  Document,
  UploadFilled,
  Warning,
  Download,
  Delete,
  Files,
  Picture
} from '@element-plus/icons-vue'
// ============================================================
// 新增：导入 API
// ============================================================
import { getProjectDetail, updateProject } from '@/api/project'

const router = useRouter()
const route = useRoute()

// ... 其他代码保持不变 ...

// ============================================================
// 获取详情 - 调用真实 API
// ============================================================
const fetchDetail = async () => {
  const id = route.params.id as string
  if (!id) {
    ElMessage.error('无效的项目ID')
    router.push('/project')
    return
  }

  loading.value = true
  try {
    const res = await getProjectDetail(Number(id))
    
    if (res.code === 0 && res.data) {
      const data = res.data
      formData.id = data.id
      formData.projectNo = data.project_no
      formData.name = data.name
      formData.customer = data.customer
      formData.budget = data.budget || 0
      formData.spent = data.spent || 0
      formData.progress = data.progress || 0
      formData.priority = data.priority || 'medium'
      formData.status = data.status || 'planning'
      formData.startDate = data.start_date || ''
      formData.deadline = data.deadline || ''
      formData.projectManager = data.project_manager || ''
      formData.description = data.description || ''
      formData.remark = data.remark || ''
    }
  } catch (error) {
    ElMessage.error('加载数据失败，请重试')
  } finally {
    loading.value = false
  }
}

// ============================================================
// 更新项目 - 调用真实 API
// ============================================================
const confirmSubmit = async () => {
  submitting.value = true
  try {
    const submitData = {
      name: formData.name,
      customer: formData.customer,
      budget: formData.budget,
      spent: formData.spent,
      progress: formData.progress,
      priority: formData.priority,
      status: formData.status,
      startDate: formData.startDate,
      deadline: formData.deadline,
      projectManager: formData.projectManager,
      description: formData.description,
      remark: formData.remark
    }
    
    const res = await updateProject(formData.id, submitData)
    
    if (res.code === 0) {
      ElMessage.success('项目更新成功！')
      submitDialogVisible.value = false
      router.push(`/project/detail/${formData.id}`)
    } else {
      ElMessage.error(res.message || '更新失败，请重试')
    }
  } catch (error: any) {
    ElMessage.error(error.message || '更新失败，请重试')
  } finally {
    submitting.value = false
  }
}
</script>