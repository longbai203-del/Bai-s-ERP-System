<script setup lang="ts">
import { ref, reactive, computed, onMounted } from 'vue'
import { useRouter, useRoute } from 'vue-router'
import { ElMessage, ElMessageBox } from 'element-plus'
import {
  ArrowLeft,
  Folder,
  Edit,
  Download,
  Delete,
  InfoFilled,
  Files,
  User,
  Flag,
  Operation,
  Printer,
  WarningFilled,
  Plus,
  TrendCharts,
  Warning,
  Picture,
  VideoCamera,
  Document,
  Grid,
  Clock,
  SuccessFilled
} from '@element-plus/icons-vue'
// ============================================================
// 新增：导入 API
// ============================================================
import { getProjectDetail, deleteProject } from '@/api/project'

const router = useRouter()
const route = useRoute()

// ... 其他代码保持不变 ...

// ============================================================
// 获取详情 - 调用真实 API
// ============================================================
const fetchDetail = async () => {
  const id = route.params.id as string
  if (!id) {
    ElMessage.error('无效的项目ID')
    router.push('/project')
    return
  }

  loading.value = true
  try {
    const res = await getProjectDetail(Number(id))
    
    if (res.code === 0 && res.data) {
      // 映射数据
      const data = res.data
      detailData.id = data.id
      detailData.projectNo = data.project_no
      detailData.name = data.name
      detailData.customer = data.customer
      detailData.budget = data.budget || 0
      detailData.spent = data.spent || 0
      detailData.progress = data.progress || 0
      detailData.priority = data.priority || 'medium'
      detailData.status = data.status || 'planning'
      detailData.startDate = data.start_date || ''
      detailData.deadline = data.deadline || ''
      detailData.projectManager = data.project_manager || ''
      detailData.description = data.description || ''
      detailData.remark = data.remark || ''
      detailData.createdAt = data.created_at || ''
      detailData.updatedAt = data.updated_at || ''
      
      // 团队数据
      teamMembers.value = data.team || [
        { name: 'Ahmed Al-Fahd', role: '项目经理', status: 'active' }
      ]
      
      // 里程碑数据
      milestones.value = data.milestones || []
    }
  } catch (error) {
    ElMessage.error('加载详情失败，请重试')
  } finally {
    loading.value = false
  }
}

// ============================================================
// 删除项目 - 调用 API
// ============================================================
const confirmDelete = async () => {
  deleteLoading.value = true
  try {
    await deleteProject(detailData.id)
    ElMessage.success('删除成功！')
    deleteDialogVisible.value = false
    router.push('/project')
  } catch (error) {
    ElMessage.error('删除失败，请重试')
  } finally {
    deleteLoading.value = false
  }
}
</script>