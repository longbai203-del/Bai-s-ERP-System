<template>
  <div class="orders-create">
    <el-card>
      <template #header>
        <div class="card-header">
          <span>创建 orders</span>
    <template>
  <div class="orders-create">
    <el-card class="form-card" shadow="hover">
      <template #header>
        <div class="card-header">
          <div class="header-left">
            <el-button type="default" @click="handleBack">
              <el-icon><ArrowLeft /></el-icon> 返回列表
            </el-button>
            <span class="header-title">创建新订单</span>
            <el-tag type="info" size="large" effect="plain">草稿</el-tag>
          </div>
          <div class="header-actions">
            <el-button @click="handleSaveDraft" :loading="draftLoading">
              <el-icon><Document /></el-icon> 保存草稿
            </el-button>
            <el-button type="primary" :loading="submitLoading" @click="handleSubmit">
              <el-icon><Check /></el-icon> 提交订单
            </el-button>
          </div>
        </div>
      </template>

      <el-form
        ref="formRef"
        :model="formData"
        :rules="formRules"
        label-width="120px"
        label-position="right"
        class="create-form"
        size="default"
      >
        <!-- 基本信息 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            基本信息
          </div>

          <el-row :gutter="24">
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="订单编号" prop="orderNo">
                <el-input v-model="formData.orderNo" placeholder="自动生成" disabled />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="客户名称" prop="customer" required>
                <el-select
                  v-model="formData.customer"
                  placeholder="请选择客户"
                  filterable
                  allow-create
                  style="width: 100%"
                  @change="handleCustomerChange"
                >
                  <el-option
                    v-for="item in customerOptions"
                    :key="item.value"
                    :label="item.label"
                    :value="item.value"
                  />
                </el-select>
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="联系电话" prop="phone">
                <el-input v-model="formData.phone" placeholder="请输入联系电话" />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="下单日期" prop="orderDate" required>
                <el-date-picker
                  v-model="formData.orderDate"
                  type="date"
                  placeholder="选择日期"
                  value-format="YYYY-MM-DD"
                  style="width: 100%"
                />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="支付方式" prop="paymentMethod">
                <el-select v-model="formData.paymentMethod" placeholder="请选择支付方式" style="width: 100%">
                  <el-option label="微信支付" value="微信支付" />
                  <el-option label="支付宝" value="支付宝" />
                  <el-option label="银行转账" value="银行转账" />
                  <el-option label="现金" value="现金" />
                  <el-option label="信用卡" value="信用卡" />
                </el-select>
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12" :lg="8">
              <el-form-item label="订单状态" prop="status">
                <el-select v-model="formData.status" disabled style="width: 100%">
                  <el-option label="待处理" value="pending" />
                  <el-option label="处理中" value="processing" />
                  <el-option label="已完成" value="completed" />
                  <el-option label="已取消" value="cancelled" />
                </el-select>
              </el-form-item>
            </el-col>
          </el-row>
        </div>

        <!-- 订单明细 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            订单明细
            <span class="section-tip">添加订单商品或服务项目</span>
          </div>

          <el-row>
            <el-col :span="24">
              <div class="items-toolbar">
                <el-button type="primary" size="small" @click="addItem">
                  <el-icon><Plus /></el-icon> 添加商品
                </el-button>
                <el-button type="warning" size="small" @click="addServiceItem">
                  <el-icon><Service /></el-icon> 添加服务
                </el-button>
                <el-button type="danger" size="small" @click="clearItems" :disabled="formData.items.length === 0">
                  <el-icon><Delete /></el-icon> 清空明细
                </el-button>
              </div>

              <el-table
                :data="formData.items"
                border
                style="width: 100%"
                v-loading="itemsLoading"
              >
                <el-table-column type="index" label="#" width="55" align="center" />
                <el-table-column label="项目名称" min-width="180">
                  <template #default="{ row, $index }">
                    <el-input
                      v-model="row.name"
                      placeholder="请输入商品/服务名称"
                      clearable
                      @blur="calculateItemTotal($index)"
                    />
                  </template>
                </el-table-column>
                <el-table-column label="规格/型号" width="150">
                  <template #default="{ row }">
                    <el-input v-model="row.spec" placeholder="规格" clearable />
                  </template>
                </el-table-column>
                <el-table-column label="数量" width="130" align="center">
                  <template #default="{ row, $index }">
                    <el-input-number
                      v-model="row.quantity"
                      :min="1"
                      :max="9999"
                      controls-position="right"
                      style="width: 100%"
                      @change="calculateItemTotal($index)"
                    />
                  </template>
                </el-table-column>
                <el-table-column label="单价 (¥)" width="150" align="right">
                  <template #default="{ row, $index }">
                    <el-input-number
                      v-model="row.price"
                      :min="0"
                      :precision="2"
                      :max="999999.99"
                      controls-position="right"
                      style="width: 100%"
                      @change="calculateItemTotal($index)"
                    />
                  </template>
                </el-table-column>
                <el-table-column label="小计 (¥)" width="150" align="right">
                  <template #default="{ row }">
                    <span style="font-weight: 600; color: #409eff;">
                      {{ formatNumber(row.quantity * row.price) }}
                    </span>
                  </template>
                </el-table-column>
                <el-table-column label="操作" width="80" align="center">
                  <template #default="{ $index }">
                    <el-button
                      type="danger"
                      size="small"
                      link
                      @click="removeItem($index)"
                    >
                      <el-icon><Delete /></el-icon>
                    </el-button>
                  </template>
                </el-table-column>
              </el-table>

              <!-- 订单合计 -->
              <div class="order-total">
                <div class="total-row">
                  <span class="total-label">商品数量：</span>
                  <span class="total-value">{{ totalItems }} 件</span>
                </div>
                <div class="total-row">
                  <span class="total-label">小计：</span>
                  <span class="total-value">¥{{ formatNumber(subtotal) }}</span>
                </div>
                <div class="total-row">
                  <span class="total-label">折扣 ({{ formData.discount }}%)：</span>
                  <span class="total-value" style="color: #e6a23c;">
                    -¥{{ formatNumber(discountAmount) }}
                  </span>
                </div>
                <div class="total-row grand-total">
                  <span class="total-label">订单总额：</span>
                  <span class="total-value">¥{{ formatNumber(totalAmount) }}</span>
                </div>
              </div>
            </el-col>
          </el-row>
        </div>

        <!-- 折扣与备注 -->
        <div class="form-section">
          <div class="section-title">
            <span class="section-indicator"></span>
            折扣与备注
          </div>

          <el-row :gutter="24">
            <el-col :xs="24" :sm="12">
              <el-form-item label="折扣 (%)" prop="discount">
                <el-slider
                  v-model="formData.discount"
                  :min="0"
                  :max="100"
                  :step="1"
                  show-input
                  input-size="small"
                  style="width: 100%"
                />
              </el-form-item>
            </el-col>
            <el-col :xs="24" :sm="12">
              <el-form-item label="优惠券" prop="coupon">
                <el-input v-model="formData.coupon" placeholder="请输入优惠券码" clearable>
                  <template #append>
                    <el-button type="primary" size="small" @click="applyCoupon">应用</el-button>
                  </template>
                </el-input>
              </el-form-item>
            </el-col>
            <el-col :span="24">
              <el-form-item label="备注" prop="remark">
                <el-input
                  v-model="formData.remark"
                  type="textarea"
                  :rows="3"
                  placeholder="请输入备注信息（可选）"
                  maxlength="500"
                  show-word-limit
                />
              </el-form-item>
            </el-col>
          </el-row>
        </div>

        <!-- 表单底部 -->
        <el-divider />
        <div class="form-footer">
          <div class="footer-left">
            <el-button @click="handleBack">
              <el-icon><ArrowLeft /></el-icon> 返回
            </el-button>
            <el-button @click="handleReset">
              <el-icon><Refresh /></el-icon> 重置
            </el-button>
          </div>
          <div class="footer-right">
            <el-button @click="handleSaveDraft" :loading="draftLoading">
              <el-icon><Document /></el-icon> 保存草稿
            </el-button>
            <el-button type="primary" :loading="submitLoading" @click="handleSubmit">
              <el-icon><Check /></el-icon> 提交订单
            </el-button>
          </div>
        </div>
      </el-form>
    </el-card>

    <!-- 提交确认对话框 -->
    <el-dialog
      v-model="submitDialogVisible"
      title="提交订单确认"
      width="440px"
      :close-on-click-modal="false"
    >
      <div class="submit-confirm">
        <el-icon color="#e6a23c" size="56"><Warning /></el-icon>
        <p>确定要提交该订单吗？</p>
        <div class="order-summary">
          <div class="summary-row">
            <span>客户：</span>
            <strong>{{ formData.customer || '未选择' }}</strong>
          </div>
          <div class="summary-row">
            <span>订单总额：</span>
            <strong style="color: #409eff; font-size: 20px;">
              ¥{{ formatNumber(totalAmount) }}
            </strong>
          </div>
          <div class="summary-row">
            <span>商品数量：</span>
            <strong>{{ totalItems }} 件</strong>
          </div>
        </div>
        <p class="submit-hint">提交后将进入审批流程，请确保信息准确无误</p>
      </div>
      <template #footer>
        <el-button @click="submitDialogVisible = false">取消</el-button>
        <el-button type="primary" :loading="submitLoading" @click="confirmSubmit">
          确定提交
        </el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup lang="ts">
import { ref, reactive, computed, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { ElMessage, ElMessageBox } from 'element-plus'
import type { FormInstance, FormRules } from 'element-plus'
import {
  ArrowLeft,
  Document,
  Check,
  Refresh,
  Plus,
  Delete,
  Service,
  Warning
} from '@element-plus/icons-vue'
// ============================================================
// API 导入
// ============================================================
import { createOrder } from '@/api/modules/orders'

const router = useRouter()

// ========== 响应式数据 ==========
const formRef = ref<FormInstance>()
const draftLoading = ref(false)
const submitLoading = ref(false)
const submitDialogVisible = ref(false)
const itemsLoading = ref(false)

// 客户选项
const customerOptions = ref([
  { label: '张三', value: '张三' },
  { label: '李四', value: '李四' },
  { label: '王五', value: '王五' },
  { label: '赵六', value: '赵六' },
  { label: '孙七', value: '孙七' },
  { label: '周八', value: '周八' },
  { label: '吴九', value: '吴九' },
  { label: '郑十', value: '郑十' },
  { label: '钱十一', value: '钱十一' },
  { label: '冯十二', value: '冯十二' }
])

// 表单数据
const formData = reactive({
  orderNo: '',
  customer: '',
  phone: '',
  orderDate: '',
  paymentMethod: '',
  status: 'pending',
  items: [] as Array<{ name: string; spec: string; quantity: number; price: number }>,
  discount: 0,
  coupon: '',
  remark: ''
})

// ========== 表单验证规则 ==========
const formRules: FormRules = {
  customer: [
    { required: true, message: '请选择客户', trigger: 'change' }
  ],
  orderDate: [
    { required: true, message: '请选择下单日期', trigger: 'change' }
  ],
  phone: [
    { pattern: /^1[3-9]\d{9}$/, message: '请输入正确的手机号码', trigger: 'blur' }
  ],
  items: [
    {
      validator: (rule: any, value: any[], callback: any) => {
        if (value.length === 0) {
          callback(new Error('请至少添加一个商品或服务项目'))
        } else {
          const hasEmpty = value.some(item => !item.name || item.name.trim() === '')
          if (hasEmpty) {
            callback(new Error('请完善所有项目名称'))
          } else {
            callback()
          }
        }
      },
      trigger: 'change'
    }
  ]
}

// ========== 计算属性 ==========
const formatNumber = (num: number) => {
  return num.toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const totalItems = computed(() => {
  return formData.items.reduce((sum, item) => sum + item.quantity, 0)
})

const subtotal = computed(() => {
  return formData.items.reduce((sum, item) => sum + item.quantity * item.price, 0)
})

const discountAmount = computed(() => {
  return subtotal.value * (formData.discount / 100)
})

const totalAmount = computed(() => {
  return subtotal.value - discountAmount
})

// ========== 生成订单编号 ==========
const generateOrderNo = () => {
  const now = new Date()
  const year = now.getFullYear()
  const month = String(now.getMonth() + 1).padStart(2, '0')
  const day = String(now.getDate()).padStart(2, '0')
  const random = String(Math.floor(Math.random() * 10000)).padStart(4, '0')
  return `ORD-${year}${month}${day}-${random}`
}

// ========== 初始化 ==========
const initForm = () => {
  formData.orderNo = generateOrderNo()
  formData.orderDate = new Date().toISOString().split('T')[0]
}

// ========== 订单明细操作 ==========
const addItem = () => {
  formData.items.push({
    name: '',
    spec: '',
    quantity: 1,
    price: 0
  })
}

const addServiceItem = () => {
  formData.items.push({
    name: '',
    spec: '服务',
    quantity: 1,
    price: 0
  })
}

const removeItem = (index: number) => {
  ElMessageBox.confirm('确定要删除该项目吗？', '提示', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  }).then(() => {
    formData.items.splice(index, 1)
    ElMessage.success('已删除')
  }).catch(() => {})
}

const clearItems = () => {
  ElMessageBox.confirm('确定要清空所有明细吗？', '提示', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  }).then(() => {
    formData.items = []
    ElMessage.success('已清空')
  }).catch(() => {})
}

const calculateItemTotal = (index: number) => {
  const item = formData.items[index]
  if (item.quantity < 1) {
    item.quantity = 1
  }
  if (item.price < 0) {
    item.price = 0
  }
}

// ========== 客户变更 ==========
const handleCustomerChange = (value: string) => {
  // 模拟自动填充电话
  const phoneMap: Record<string, string> = {
    '张三': '13800001001',
    '李四': '13800001002',
    '王五': '13800001003',
    '赵六': '13800001004',
    '孙七': '13800001005'
  }
  if (phoneMap[value]) {
    formData.phone = phoneMap[value]
  }
}

// ========== 优惠券 ==========
const applyCoupon = () => {
  if (!formData.coupon) {
    ElMessage.warning('请输入优惠券码')
    return
  }
  if (formData.coupon === 'VIP2024') {
    formData.discount = 10
    ElMessage.success('优惠券应用成功！享受10%折扣')
  } else if (formData.coupon === 'NEWUSER') {
    formData.discount = 15
    ElMessage.success('优惠券应用成功！享受15%折扣')
  } else {
    ElMessage.warning('无效的优惠券码')
  }
}

// ========== 表单验证 ==========
const validateForm = async (): Promise<boolean> => {
  if (!formRef.value) return false
  try {
    await formRef.value.validate()
    return true
  } catch {
    ElMessage.warning('请完善表单信息')
    return false
  }
}

// ========== 保存草稿 ==========
const handleSaveDraft = async () => {
  const valid = await validateForm()
  if (!valid) return

  if (formData.items.length === 0) {
    ElMessage.warning('请至少添加一个商品或服务项目')
    return
  }

  draftLoading.value = true
  try {
    await new Promise(resolve => setTimeout(resolve, 800))
    ElMessage.success('草稿保存成功！')
  } // catch (error) {
    // ElMessage.error("保存失败，请重试")
  } finally {
    draftLoading.value = false
  }
}

// ========== 提交订单 ==========
const handleSubmit = async () => {
  const valid = await validateForm()
  if (!valid) return

  if (formData.items.length === 0) {
    ElMessage.warning('请至少添加一个商品或服务项目')
    return
  }

  const hasEmpty = formData.items.some(item => !item.name || item.name.trim() === '')
  if (hasEmpty) {
    ElMessage.warning('请完善所有项目名称')
    return
  }

  submitDialogVisible.value = true
}

const confirmSubmit = async () => {
  submitting.value = true
  try {
    const submitData = {
      customer: formData.customer,
      phone: formData.phone,
      items: formData.items.map(item => ({
        name: item.name,
        spec: item.spec,
        quantity: item.quantity,
        price: item.price
      })),
      paymentMethod: formData.paymentMethod,
      discount: formData.discount,
      remark: formData.remark
    }
    const res = await createOrder(submitData)
    if (res.code === 0) {
      ElMessage.success('订单创建成功！')
      submitDialogVisible.value = false
      router.push('/orders')
    } else {
      ElMessage.error(res.message || '创建失败，请重试')
    }
  } catch (error: any) {
    ElMessage.error(error.message || '创建失败，请重试')
  } finally {
    submitting.value = false
  }
} // catch (error) {
    ElMessage.error('提交失败，请重试')
  } finally {
    submitLoading.value = false
  }
}

// ========== 其他操作 ==========
const handleBack = () => {
  router.push('/orders')
}

const handleReset = () => {
  ElMessageBox.confirm('确定要重置表单吗？所有数据将被清空', '确认重置', {
    confirmButtonText: '确定',
    cancelButtonText: '取消',
    type: 'warning'
  }).then(() => {
    formData.customer = ''
    formData.phone = ''
    formData.paymentMethod = ''
    formData.items = []
    formData.discount = 0
    formData.coupon = ''
    formData.remark = ''
    formData.orderNo = generateOrderNo()
    formData.orderDate = new Date().toISOString().split('T')[0]
    ElMessage.success('已重置')
  }).catch(() => {})
}

// ========== 生命周期 ==========
onMounted(() => {
  initForm()
})
</script>

<style scoped>
.orders-create {
  padding: 20px;
  background: #f5f7fa;
  min-height: 100vh;
}

.form-card {
  border-radius: 12px;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.header-title {
  font-size: 18px;
  font-weight: 600;
  color: #303133;
}

.header-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.create-form {
  padding: 8px 0;
}

.form-section {
  background: #fafbfc;
  border-radius: 8px;
  padding: 20px 24px;
  margin-bottom: 24px;
}

.form-section:last-of-type {
  margin-bottom: 0;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 15px;
  font-weight: 600;
  color: #303133;
  margin-bottom: 20px;
  flex-wrap: wrap;
  gap: 8px;
}

.section-indicator {
  display: inline-block;
  width: 4px;
  height: 18px;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  border-radius: 2px;
  margin-right: 10px;
}

.section-tip {
  font-size: 12px;
  font-weight: 400;
  color: #909399;
  margin-left: 8px;
}

.items-toolbar {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.order-total {
  margin-top: 16px;
  padding: 16px 20px;
  background: #f5f7fa;
  border-radius: 8px;
  border: 1px solid #ebeef5;
}

.total-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 4px 0;
  font-size: 14px;
}

.total-label {
  color: #909399;
  margin-right: 8px;
  min-width: 100px;
  text-align: right;
}

.total-value {
  font-weight: 500;
  min-width: 120px;
  text-align: right;
}

.grand-total {
  padding-top: 8px;
  margin-top: 8px;
  border-top: 2px solid #dcdfe6;
}

.grand-total .total-label {
  font-size: 16px;
  font-weight: 600;
  color: #303133;
}

.grand-total .total-value {
  font-size: 22px;
  font-weight: 700;
  color: #409eff;
}

.form-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
