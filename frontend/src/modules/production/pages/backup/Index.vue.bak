  background: linear-gradient(135deg, #8b5cf6, #a78bfa);
}
.stat-icon.quality {
  background: linear-gradient(135deg, #e6a23c, #f0c78a);
}

.stat-info {
  flex: 1;
  min-width: 0;
}

.stat-label {
  font-size: 13px;
