<template>
  <div class="production-index">
    <!-- 页面标题 -->
    <div class="page-header">
      <div class="header-left">
        <h1>
          <el-icon :size="28" color="#4F46E5"><Factory /></el-icon>
          生产管理
        </h1>
        <span class="subtitle">生产运营概览与实时监控</span>
      </div>
      <div class="header-actions">
        <el-button type="primary" @click="handleCreateWorkOrder">
          <el-icon><Plus /></el-icon> 新建工单
        </el-button>
        <el-button type="success" @click="handleCreatePlan">
          <el-icon><Plus /></el-icon> 新建计划
        </el-button>
        <el-button @click="handleRefresh">
          <el-icon><RefreshRight /></el-icon> 刷新
        </el-button>
      </div>
    </div>

    <!-- 统计卡片 -->
    <el-row :gutter="20" class="stat-cards">
      <el-col :xs="24" :sm="12" :lg="6">
        <el-card class="stat-card" shadow="hover">
          <div class="stat-content">
            <div class="stat-icon total">
              <el-icon><Document /></el-icon>
            </div>
            <div class="stat-info">
              <div class="stat-label">今日产量</div>
              <div class="stat-value">{{ formatNumber(stats.todayProduction) }}</div>
              <div class="stat-change positive">
                <el-icon><Top /></el-icon>
                {{ stats.productionGrowth }}%
              </div>
            </div>
          </div>
        </el-card>
      </el-col>
      <el-col :xs="24" :sm="12" :lg="6">
        <el-card class="stat-card" shadow="hover">
          <div class="stat-content">
            <div class="stat-icon orders">
              <el-icon><List /></el-icon>
            </div>
            <div class="stat-info">
              <div class="stat-label">进行中工单</div>
              <div class="stat-value">{{ stats.activeOrders }}</div>
              <div class="stat-change positive">
                <el-icon><Top /></el-icon>
                {{ stats.orderGrowth }}%
              </div>
            </div>
          </div>
        </el-card>
      </el-col>
      <el-col :xs="24" :sm="12" :lg="6">
        <el-card class="stat-card" shadow="hover">
          <div class="stat-content">
            <div class="stat-icon rate">
              <el-icon><TrendCharts /></el-icon>
            </div>
            <div class="stat-info">
              <div class="stat-label">设备利用率</div>
              <div class="stat-value">{{ stats.utilizationRate }}%</div>
              <div class="stat-change positive">
                <el-icon><Top /></el-icon>
                {{ stats.utilizationGrowth }}%
              </div>
            </div>
          </div>
        </el-card>
      </el-col>
      <el-col :xs="24" :sm="12" :lg="6">
        <el-card class="stat-card" shadow="hover">
          <div class="stat-content">
            <div class="stat-icon quality">
              <el-icon><Select /></el-icon>
            </div>
            <div class="stat-info">
              <div class="stat-label">合格率</div>
              <div class="stat-value">{{ stats.qualityRate }}%</div>
              <div class="stat-change positive">
                <el-icon><Top /></el-icon>
                {{ stats.qualityGrowth }}%
              </div>
            </div>
          </div>
        </el-card>
      </el-col>
    </el-row>

    <!-- 图表区域 -->
    <el-row :gutter="20" class="chart-row">
      <el-col :xs="24" :lg="16">
        <el-card class="chart-card" shadow="hover">
          <template #header>
            <div class="card-header">
              <span>生产趋势</span>
              <el-radio-group v-model="trendPeriod" size="small">
                <el-radio-button label="week">本周</el-radio-button>
                <el-radio-button label="month">本月</el-radio-button>
                <el-radio-button label="quarter">本季度</el-radio-button>
              </el-radio-group>
            </div>
          </template>
          <div ref="trendChartRef" class="chart-container"></div>
        </el-card>
      </el-col>
      <el-col :xs="24" :lg="8">
        <el-card class="chart-card" shadow="hover">
          <template #header>
            <div class="card-header">
              <span>工单状态分布</span>
            </div>
          </template>
          <div ref="pieChartRef" class="chart-container"></div>
        </el-card>
      </el-col>
    </el-row>

    <!-- 工单状态 -->
    <el-row :gutter="20" class="status-row">
      <el-col :xs="24" :lg="8">
        <el-card class="status-card" shadow="hover">
          <template #header>
            <span class="card-title">
              <el-tag type="warning" size="small">待处理</el-tag>
              待生产工单
            </span>
            <el-button size="small" type="primary" link @click="handleViewAll('pending')">查看全部</el-button>
          </template>
          <div class="status-list">
            <div v-for="order in pendingOrders" :key="order.id" class="status-item">
              <div class="order-info">
                <span class="order-no">{{ order.workOrderNo }}</span>
                <span class="order-product">{{ order.product }}</span>
              </div>
              <div class="order-meta">
                <span class="order-qty">×{{ order.quantity }}</span>
                <el-tag size="small" :type="order.priority === 'high' ? 'danger' : 'warning'">
                  {{ order.priority === 'high' ? '紧急' : '正常' }}
                </el-tag>
              </div>
            </div>
            <div v-if="pendingOrders.length === 0" class="empty-status">
              <el-empty description="暂无待生产工单" :image-size="50" />
            </div>
          </div>
        </el-card>
      </el-col>

      <el-col :xs="24" :lg="8">
        <el-card class="status-card" shadow="hover">
          <template #header>
            <span class="card-title">
              <el-tag type="primary" size="small">进行中</el-tag>
              生产中工单
            </span>
            <el-button size="small" type="primary" link @click="handleViewAll('processing')">查看全部</el-button>
          </template>
          <div class="status-list">
            <div v-for="order in processingOrders" :key="order.id" class="status-item">
              <div class="order-info">
                <span class="order-no">{{ order.workOrderNo }}</span>
                <span class="order-product">{{ order.product }}</span>
              </div>
              <div class="order-meta">
                <span class="order-progress">{{ order.completionRate }}%</span>
                <el-progress :percentage="order.completionRate" :show-text="false" style="width: 60px;" />
              </div>
            </div>
            <div v-if="processingOrders.length === 0" class="empty-status">
              <el-empty description="暂无生产中工单" :image-size="50" />
            </div>
          </div>
        </el-card>
      </el-col>

      <el-col :xs="24" :lg="8">
        <el-card class="status-card" shadow="hover">
          <template #header>
            <span class="card-title">
              <el-tag type="success" size="small">已完成</el-tag>
              今日完成
            </span>
            <el-button size="small" type="primary" link @click="handleViewAll('completed')">查看全部</el-button>
          </template>
          <div class="status-list">
            <div v-for="order in completedOrders" :key="order.id" class="status-item">
              <div class="order-info">
                <span class="order-no">{{ order.workOrderNo }}</span>
                <span class="order-product">{{ order.product }}</span>
              </div>
              <div class="order-meta">
                <span class="order-qty">✅ {{ order.quantity }}件</span>
                <el-tag size="small" type="success">已完成</el-tag>
              </div>
            </div>
            <div v-if="completedOrders.length === 0" class="empty-status">
              <el-empty description="今日暂无完成工单" :image-size="50" />
            </div>
          </div>
        </el-card>
      </el-col>
    </el-row>

    <!-- 设备状态 -->
    <el-card class="equipment-card" shadow="hover">
      <template #header>
        <div class="card-header">
          <span class="card-title">
            <el-icon><Monitor /></el-icon> 设备状态
          </span>
          <el-button size="small" @click="handleViewEquipment">查看全部设备</el-button>
        </div>
      </template>
      <el-row :gutter="16">
        <el-col :xs="12" :sm="8" :lg="4" v-for="equipment in equipments" :key="equipment.id">
          <div class="equipment-item" :class="equipment.status">
            <div class="equipment-icon">
              <el-icon :size="32">
                <component :is="getEquipmentIcon(equipment.type)" />
              </el-icon>
            </div>
            <div class="equipment-name">{{ equipment.name }}</div>
            <div class="equipment-status">
              <el-tag :type="getEquipmentStatusTag(equipment.status)" size="small">
                {{ getEquipmentStatusLabel(equipment.status) }}
              </el-tag>
            </div>
            <div class="equipment-meta">
              <span>利用率: {{ equipment.utilization }}%</span>
            </div>
          </div>
        </el-col>
      </el-row>
    </el-card>

    <!-- 快捷入口 -->
    <el-card class="quick-actions-card" shadow="hover">
      <template #header>
        <span class="card-title">快捷入口</span>
      </template>
      <el-row :gutter="16">
        <el-col :xs="12" :sm="8" :md="4" v-for="action in quickActions" :key="action.key">
          <div class="quick-action-item" @click="handleQuickAction(action.key)">
            <el-icon :size="32" :color="action.color"><component :is="action.icon" /></el-icon>
            <span>{{ action.label }}</span>
          </div>
        </el-col>
      </el-row>
    </el-card>
  </div>
</template>

<script setup lang="ts">
import { ref, reactive, onMounted, nextTick } from 'vue'
import { useRouter } from 'vue-router'
import { ElMessage } from 'element-plus'
import * as echarts from 'echarts'
import {
  Factory,
  Plus,
  RefreshRight,
  Document,
  List,
  TrendCharts,
  Select,
  Top,
  Monitor,
  Cpu,
  Tools,
  Box,
  Setting,
  DataLine,
  Clock
} from '@element-plus/icons-vue'

const router = useRouter()

// ========== 响应式数据 ==========
const trendPeriod = ref('month')
const trendChartRef = ref<HTMLDivElement | null>(null)
const pieChartRef = ref<HTMLDivElement | null>(null)
let trendChart: echarts.ECharts | null = null
let pieChart: echarts.ECharts | null = null

// 统计数据
const stats = reactive({
  todayProduction: 12580,
  productionGrowth: 12.5,
  activeOrders: 32,
  orderGrowth: 8.3,
  utilizationRate: 85,
  utilizationGrowth: 5.2,
  qualityRate: 97.5,
  qualityGrowth: 2.1
})

// 待生产工单
const pendingOrders = ref([
  { id: 1, workOrderNo: 'WO-2024-001', product: 'iPhone 15 Pro Max', quantity: 500, priority: 'high' },
  { id: 2, workOrderNo: 'WO-2024-002', product: '三星 Galaxy S24 Ultra', quantity: 300, priority: 'medium' },
  { id: 3, workOrderNo: 'WO-2024-003', product: 'MacBook Pro 16"', quantity: 150, priority: 'high' }
])

// 生产中工单
const processingOrders = ref([
  { id: 4, workOrderNo: 'WO-2024-004', product: 'iPad Pro 12.9"', quantity: 200, completionRate: 65 },
  { id: 5, workOrderNo: 'WO-2024-005', product: 'AirPods Pro 2', quantity: 1000, completionRate: 80 }
])

// 今日完成工单
const completedOrders = ref([
  { id: 6, workOrderNo: 'WO-2024-006', product: 'Apple Watch Ultra 2', quantity: 150 },
  { id: 7, workOrderNo: 'WO-2024-007', product: 'iMac 24"', quantity: 50 }
])

// 设备状态
const equipments = ref([
  { id: 1, name: '注塑机A', type: 'injection', status: 'running', utilization: 92 },
  { id: 2, name: 'SMT贴片机B', type: 'smt', status: 'running', utilization: 88 },
  { id: 3, name: '组装流水线C', type: 'assembly', status: 'idle', utilization: 45 },
  { id: 4, name: '检测设备D', type: 'testing', status: 'maintenance', utilization: 0 },
  { id: 5, name: '包装机E', type: 'packaging', status: 'running', utilization: 78 },
  { id: 6, name: 'CNC加工中心F', type: 'cnc', status: 'running', utilization: 85 }
])

// 快捷入口
const quickActions = ref([
  { key: 'bom', label: 'BOM管理', icon: 'Document', color: '#409eff' },
  { key: 'workorder', label: '工单管理', icon: 'List', color: '#67c23a' },
  { key: 'plan', label: '生产计划', icon: 'Calendar', color: '#e6a23c' },
  { key: 'quality', label: '质检管理', icon: 'Select', color: '#8b5cf6' },
  { key: 'equipment', label: '设备管理', icon: 'Cpu', color: '#f56c6c' },
  { key: 'mrp', label: 'MRP运算', icon: 'DataLine', color: '#409eff' }
])

// ========== 计算属性 ==========
const formatNumber = (num: number) => {
  return num.toLocaleString('zh-CN', { minimumFractionDigits: 0, maximumFractionDigits: 0 })
}

const getEquipmentIcon = (type: string) => {
  const map: Record<string, any> = {
    injection: Cpu,
    smt: Tools,
    assembly: Box,
    testing: Setting,
    packaging: Box,
    cnc: Tools
  }
  return map[type] || Cpu
}

const getEquipmentStatusTag = (status: string) => {
  const map: Record<string, string> = {
    running: 'success',
    idle: 'info',
    maintenance: 'warning',
    stopped: 'danger'
  }
  return map[status] || 'info'
}

const getEquipmentStatusLabel = (status: string) => {
  const map: Record<string, string> = {
    running: '运行中',
    idle: '闲置',
    maintenance: '维护中',
    stopped: '停机'
  }
  return map[status] || status
}

// ========== 图表初始化 ==========
const initCharts = () => {
  if (trendChartRef.value) {
    trendChart = echarts.init(trendChartRef.value)
    trendChart.setOption({
      tooltip: {
        trigger: 'axis',
        formatter: (params: any) => {
          let html = `<div style="font-weight:bold;">${params[0].axisValue}</div>`
          params.forEach((p: any) => {
            html += `<div>${p.marker} ${p.seriesName}: ${p.value.toLocaleString()}</div>`
          })
          return html
        }
      },
      legend: {
        data: ['计划产量', '实际产量', '合格率'],
        bottom: 0
      },
      grid: {
        left: '3%',
        right: '4%',
        bottom: '20%',
        top: '5%',
        containLabel: true
      },
      xAxis: {
        type: 'category',
        data: ['1日', '3日', '5日', '7日', '9日', '11日', '13日', '15日', '17日', '19日', '21日', '23日']
      },
      yAxis: [
        {
          type: 'value',
          name: '产量',
          splitLine: { lineStyle: { color: '#f0f0f0' } }
        },
        {
          type: 'value',
          name: '合格率 %',
          min: 0,
          max: 100,
          splitLine: { show: false }
        }
      ],
      series: [
        {
          name: '计划产量',
          type: 'bar',
          data: [1200, 1100, 1300, 1400, 1200, 1500, 1300, 1600, 1400, 1500, 1300, 1700],
          itemStyle: {
            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
              { offset: 0, color: '#409eff' },
              { offset: 1, color: '#66b1ff' }
            ]),
            borderRadius: [4, 4, 0, 0]
          }
        },
        {
          name: '实际产量',
          type: 'bar',
          data: [1100, 1050, 1250, 1350, 1150, 1450, 1250, 1550, 1350, 1450, 1250, 1650],
          itemStyle: {
            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
              { offset: 0, color: '#67c23a' },
              { offset: 1, color: '#85ce61' }
            ]),
            borderRadius: [4, 4, 0, 0]
          }
        },
        {
          name: '合格率',
          type: 'line',
          yAxisIndex: 1,
          data: [96, 95, 97, 96, 98, 97, 96, 98, 97, 99, 98, 97],
          smooth: true,
          lineStyle: { color: '#e6a23c', width: 3 },
          areaStyle: {
            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
              { offset: 0, color: 'rgba(230, 162, 60, 0.3)' },
              { offset: 1, color: 'rgba(230, 162, 60, 0.05)' }
            ])
          }
        }
      ]
    })
    window.addEventListener('resize', () => trendChart?.resize())
  }

  if (pieChartRef.value) {
    pieChart = echarts.init(pieChartRef.value)
    pieChart.setOption({
      tooltip: {
        trigger: 'item',
        formatter: (params: any) => {
          return `${params.name}<br/>工单数: ${params.value}单<br/>占比: ${params.percent}%`
        }
      },
      legend: {
        orient: 'vertical',
        right: '5%',
        top: 'center',
        itemWidth: 12,
        itemHeight: 12
      },
      series: [
        {
          type: 'pie',
          radius: ['40%', '70%'],
          center: ['40%', '50%'],
          avoidLabelOverlap: true,
          itemStyle: {
            borderRadius: 8,
            borderColor: '#fff',
            borderWidth: 2
          },
          label: {
            show: true,
            formatter: (params: any) => {
              return `${params.name}\n${params.percent}%`
            },
            fontSize: 11
          },
          data: [
            { value: 28, name: '待生产', itemStyle: { color: '#e6a23c' } },
            { value: 32, name: '生产中', itemStyle: { color: '#409eff' } },
            { value: 26, name: '已完成', itemStyle: { color: '#67c23a' } },
            { value: 6, name: '已取消', itemStyle: { color: '#f56c6c' } }
          ]
        }
      ]
    })
    window.addEventListener('resize', () => pieChart?.resize())
  }
}

// ========== 事件处理 ==========
const handleCreateWorkOrder = () => {
  router.push('/production/workorder/create')
}

const handleCreatePlan = () => {
  router.push('/production/plan/create')
}

const handleViewAll = (status: string) => {
  router.push(`/production/workorders?status=${status}`)
}

const handleViewEquipment = () => {
  router.push('/production/equipment')
}

const handleQuickAction = (key: string) => {
  const routes: Record<string, string> = {
    bom: '/production/bom',
    workorder: '/production/workorders',
    plan: '/production/plan',
    quality: '/production/quality',
    equipment: '/production/equipment',
    mrp: '/production/mrp'
  }
  router.push(routes[key] || '/production')
}

const handleRefresh = () => {
  ElMessage.success('数据已刷新')
  nextTick(() => {
    trendChart?.resize()
    pieChart?.resize()
  })
}

// ========== 生命周期 ==========
onMounted(() => {
  nextTick(() => {
    initCharts()
  })
})
</script>

<style scoped>
