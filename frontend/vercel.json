{
  "version": 2,
  "builds": [
      {
          "src": "**/*",
          "use": "@vercel/static"
      }
  ],
  "routes": [
      {
          "src": "/assets/(.*)",
          "dest": "/src/assets/$1"
      },
      {
          "src": "/js/(.*)",
          "dest": "/src/$1"
      },
      {
          "src": "/(.*)",
          "dest": "/index.html"
      }
  ]
}